# Polymarket Data Service Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── RPC ──────────────────────────────────────────────────────
# Alchemy API key for faster RPC access (optional, falls back to public RPC)
ALCHEMY_API_KEY=

# Custom Polygon RPC URL (optional, default: https://polygon.llamarpc.com)
POLYGON_RPC_URL=https://polygon.llamarpc.com

# ── Service ──────────────────────────────────────────────────
# API server port
API_PORT=8000

# Fetcher batch size (blocks per batch in catch-up mode)
BATCH_SIZE=100

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
